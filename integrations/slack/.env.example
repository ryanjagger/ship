# Local Slack integration config.
# Copy to .env and fill in the Slack + Ship OAuth credentials for this environment.

PORT=3001

# Public URL for this integration service. For local dev, use an ngrok/cloudflared
# tunnel that forwards to http://localhost:3001.
PUBLIC_BASE_URL=https://your-tunnel.example

# Ship API base URL for the environment this integration should connect to.
SHIP_BASE_URL=http://localhost:3000

# Ship OAuth app credentials. SHIP_CLIENT_SECRET is required only for
# confidential Ship OAuth clients.
SHIP_CLIENT_ID=
SHIP_CLIENT_SECRET=
# Defaults to ${PUBLIC_BASE_URL}/ship/oauth/callback when omitted.
# SHIP_REDIRECT_URI=

# Slack app credentials.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Random string used by Slack Bolt OAuth state handling.
SLACK_STATE_SECRET=

# 32-byte encryption key for Slack/Ship tokens and webhook secrets.
# Generate with: openssl rand -hex 32
SLACK_INTEGRATION_ENC_KEY=

# Postgres database where the integration creates its slack_* tables.
DATABASE_URL=postgresql://ship:ship_dev_password@localhost:5432/ship_dev
