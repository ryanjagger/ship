{
  "name": "ship",
  "version": "0.0.0",
  "private": true,
  "description": "Ship monorepo - API + Web + Shared types",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "./scripts/dev.sh",
    "drill": "pnpm --filter @ship/drill drill",
    "docker:up": "docker compose -f docker-compose.local.yml up --build",
    "docker:down": "docker compose -f docker-compose.local.yml down",
    "docker:clean": "docker compose -f docker-compose.local.yml down -v",
    "dev:raw": "pnpm --parallel --recursive run dev",
    "dev:api": "pnpm --filter @ship/api dev",
    "dev:web": "pnpm --filter @ship/web dev",
    "dev:shared": "pnpm --filter @ship/shared dev",
    "build": "pnpm --recursive run build",
    "build:shared": "pnpm --filter @ship/shared build",
    "build:sdk": "pnpm --filter @ryanjagger/ship-sdk build",
    "build:api": "pnpm run build:shared && pnpm --filter @ship/api build",
    "build:web": "pnpm run build:shared && pnpm run build:sdk && pnpm --filter @ship/web build",
    "type-check": "pnpm --recursive run type-check",
    "lint": "eslint .",
    "lint:report": "node audit/type-safety/lint-report.mjs",
    "clean": "pnpm --recursive run clean && rm -rf node_modules",
    "test": "pnpm --filter @ship/api test && pnpm --filter @ship/web test && pnpm --filter probe test && pnpm --filter @ryanjagger/ship-sdk test",
    "test:api": "pnpm --filter @ship/api test",
    "test:web": "pnpm --filter @ship/web test",
    "test:probe": "pnpm --filter probe test",
    "test:sdk": "pnpm --filter @ryanjagger/ship-sdk test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "probe": "pnpm --filter probe probe",
    "audit:db-query-efficiency": "node --import ./api/node_modules/tsx/dist/loader.mjs audit/database-query-efficiency/run-audit.mjs",
    "worktree:init": "./scripts/worktree-init.sh",
    "db:seed": "pnpm --filter @ship/api db:seed",
    "db:seed:develop": "pnpm --filter @ship/api db:seed:develop",
    "db:migrate": "pnpm --filter @ship/api db:migrate",
    "db:orphan-check": "pnpm --filter @ship/api db:orphan-check",
    "prepare": "husky",
    "postinstall": "git config merge.ours.driver true && (command -v comply >/dev/null 2>&1 || echo '\\n⚠️  comply CLI not installed - pre-commit hooks require it\\n   Install with: pip install comply-cli\\n')"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.57.0",
    "@testcontainers/postgresql": "^11.11.0",
    "@types/supertest": "^6.0.3",
    "@vitest/ui": "^4.0.16",
    "eslint": "^9.39.4",
    "get-port": "^7.1.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "supertest": "^7.1.4",
    "testcontainers": "^11.11.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.0.16"
  }
}
