{
  "name": "@ship/cli",
  "version": "0.0.0",
  "private": true,
  "description": "Ship Platform command-line interface",
  "type": "module",
  "bin": {
    "ship": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@ship/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.3",
    "typescript": "^5.7.2",
    "vitest": "^4.0.16"
  }
}
