{
  "name": "@ship/cli",
  "version": "0.0.0",
  "private": true,
  "description": "Ship Platform command-line interface",
  "type": "module",
  "bin": {
    "ship": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "pnpm --filter @ryanjagger/ship-sdk build",
    "dev": "pnpm --filter @ryanjagger/ship-sdk dev",
    "clean": "rm -rf dist",
    "type-check": "pnpm --filter @ryanjagger/ship-sdk type-check",
    "test": "pnpm --filter @ryanjagger/ship-sdk test",
    "start": "node ../sdk/dist/cli/index.js"
  },
  "dependencies": {
    "@ryanjagger/ship-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.3",
    "typescript": "^5.7.2",
    "vitest": "^4.0.16"
  }
}
