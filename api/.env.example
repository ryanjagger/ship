# Ship API - Local Development Configuration
# Copy this to .env.local and customize values:
#   cp .env.example .env.local

# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://ship:ship_dev_password@localhost:5432/ship_dev

# Session secret (change in production)
SESSION_SECRET=dev-only-secret-do-not-use-in-production

# CORS origin (must match frontend URL)
CORS_ORIGIN=http://localhost:5173

# Environment
NODE_ENV=development

# Server port (optional, defaults to 3000)
PORT=3000

# Fleet plan review runs deterministic checks by default (no AI, no cost).
# Leave this as `none` unless you want AI rubric scoring; then set a provider
# AND its matching key below.
FLEET_AI_PROVIDER=none               # none | openai | anthropic
# FLEET_AI_MODEL=claude-haiku-4-5    # optional; defaults: anthropic→claude-haiku-4-5, openai→gpt-5.2
# ANTHROPIC_API_KEY=sk-ant-...       # required when FLEET_AI_PROVIDER=anthropic
# OPENAI_API_KEY=sk-...              # required when FLEET_AI_PROVIDER=openai

# ====================
# PIV Authentication (Optional)
# ====================
# Configure one or both providers. If neither is configured, only password auth is available.

# FPKI Validator - Primary PIV authentication provider
# Credentials are loaded from AWS Secrets Manager at startup (preferred)
# or from environment variables (fallback)
# FPKI_ISSUER_URL=https://fpki-validator.example.gov
# FPKI_CLIENT_ID=your-client-id
# FPKI_CLIENT_SECRET=your-client-secret
# FPKI_REDIRECT_URI=http://localhost:3000/api/auth/piv/callback
# FPKI_SECRET_NAME=ship/fpki-oauth-credentials

# CAIA (Treasury Customer Authentication & Identity Architecture)
# Alternative PIV authentication provider via Treasury's CAIA
# Note: CAIA's `sub` is NOT persistent - email is the primary identifier
# CAIA_ISSUER_URL=https://caia-dev.treasury.gov
# CAIA_CLIENT_ID=your-client-id
# CAIA_CLIENT_SECRET=your-client-secret
# CAIA_REDIRECT_URI=http://localhost:3000/api/auth/caia/callback
# CAIA_SECRET_NAME=ship/caia-credentials

# ====================
# Fleet — Project Plan Review (Optional AI scoring)
# ====================
# Fleet always runs free deterministic checks. Configuring a provider adds
# rubric-based quality scoring. If unset/none, Fleet runs deterministic-only.
# Provider: openai | anthropic | none (default: none)
# FLEET_AI_PROVIDER=none
# Model identifier (defaults: anthropic=claude-haiku-4-5, openai=gpt-5.2)
# FLEET_AI_MODEL=
# Provide the key matching the selected provider:
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ====================
# LangSmith — Fleet observability (Optional tracing)
# ====================
# Traces every FleetGraph run (chat + proactive plan review) to LangSmith.
# The LangGraph/LangChain chat path auto-traces from these vars; the raw-SDK
# proactive path is wrapped in fleet-ai.ts. All best-effort — never blocks Fleet.
# Set LANGSMITH_TRACING=true and provide the key to enable; leave unset to disable.
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=lsv2_pt_...        # secret — never commit; real value lives in .env.local / SSM
# LANGSMITH_PROJECT=fleet
# LANGSMITH_ENV=local

# ====================
# Webhooks — Outbound signed delivery (Optional)
# ====================
# Public /api/v1 webhooks (issue.*, project.*, etc.) signed with HMAC-SHA256.
# Two independent settings:
#
# WEBHOOK_SECRET_ENC_KEY — AES-256-GCM key used to encrypt each subscription's
#   signing secret at rest (HMAC needs the raw secret, so it can't be hashed).
#   Required to create subscriptions. 32 bytes, as 64 hex chars OR base64.
#   Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   secret — never commit; real value lives in .env.local (dev) / SSM (prod).
#   MUST stay stable per environment (rotating it makes stored secrets
#   undecryptable) and MUST differ between dev and prod.
# WEBHOOK_SECRET_ENC_KEY=
#
# WEBHOOKS_DELIVERY_ENABLED — ops kill switch for the delivery scheduler, read
#   once at boot (like FLEETGRAPH_SWEEP_ENABLED). When unset/false, subscriptions
#   and events still record but nothing is delivered; set to true to register the
#   30s retry tick + immediate post-commit dispatch. Restart to apply.
# WEBHOOKS_DELIVERY_ENABLED=false
#
# WEBHOOK_ALLOW_PRIVATE_TARGETS — dev/test escape hatch. By default webhook target
#   URLs must be public http/https hosts; loopback/private/link-local/metadata
#   addresses are rejected (SSRF guard) at create, update, and dispatch. Set to
#   true ONLY for local development (e.g. a receiver on 127.0.0.1). NEVER in prod.
# WEBHOOK_ALLOW_PRIVATE_TARGETS=false
